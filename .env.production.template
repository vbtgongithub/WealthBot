# WealthBot Production Environment Template
# Copy to .env.production and fill in real values
# =============================================================================

# ---------- Database (managed instance) ----------
DATABASE_URL=postgresql+asyncpg://user:password@your-managed-db.host:5432/wealthbot_db

# ---------- Security ----------
SECRET_KEY=          # Generate: openssl rand -hex 32
APP_ENV=production
DEBUG=false

# ---------- Redis ----------
REDIS_URL=redis://redis:6379/0
REDIS_ENABLED=true

# ---------- CORS / Hosts ----------
ALLOWED_ORIGINS=https://yourdomain.com
TRUSTED_HOSTS=yourdomain.com,api.yourdomain.com

# ---------- ML Model Paths ----------
XGBOOST_ONNX_PATH=./ml/models/xgboost_spending.onnx
CATEGORIZER_ONNX_PATH=./ml/models/categorizer.onnx
TOKENIZER_PATH=./ml/models/tokenizer
LABEL_ENCODER_PATH=./ml/models/label_encoder.json
FEATURE_CONFIG_PATH=./ml/models/feature_config.json

# ---------- Observability ----------
LOG_LEVEL=INFO
SENTRY_DSN=
SENTRY_ENABLED=false
SENTRY_TRACES_SAMPLE_RATE=0.1

# ---------- PII ----------
ENABLE_PII_MASKING=true
