# =============================================================================
# WealthBot Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://wealthbot_user:your_secure_password@localhost:5432/wealthbot_db
POSTGRES_USER=wealthbot_user
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=wealthbot_db

# -----------------------------------------------------------------------------
# Security & Authentication
# -----------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# -----------------------------------------------------------------------------
# ML Model Configuration
# -----------------------------------------------------------------------------
MODEL_PATH=./ml/models/xgboost_spending_model.pkl
TRANSFORMER_MODEL_NAME=distilbert-base-uncased

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# -----------------------------------------------------------------------------
# PII Protection (GDPR/SOC 2 Compliance)
# -----------------------------------------------------------------------------
ENABLE_PII_MASKING=true
DATA_RETENTION_DAYS=365
ENCRYPTION_KEY=your-encryption-key-for-sensitive-data
