# WealthBot Frontend Environment Variables
# Copy to .env.local for development, .env.production for production builds
# =============================================================================

# Backend API URL — the frontend Axios client uses this
NEXT_PUBLIC_API_URL=http://localhost:8000

# App name (used in metadata)
NEXT_PUBLIC_APP_NAME=WealthBot

# Sentry (optional — leave empty to disable)
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENABLED=false
